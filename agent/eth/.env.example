# Name and symbol of the NFT collection minted by the deployed contract.
NFT_NAME=CrossChain Secret NFT
NFT_SYMBOL=CCSNFT

# Address that owns the deployed contract (pause/unpause, ownership transfer).
# Defaults to the broadcasting signer when unset.
NFT_INITIAL_OWNER=0x0000000000000000000000000000000000000000

# JSON-RPC endpoint for the target network.
ETHEREUM_RPC_URL=http://127.0.0.1:8545

# Optional, for source verification on Etherscan-compatible explorers.
ETHERSCAN_API_KEY=
